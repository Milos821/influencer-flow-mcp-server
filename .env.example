# Influencer Flow MCP Server Environment Variables

# API Base URL (use your self-hosted instance or default)
# For staging: https://dev.influencer-flow.com
# For production: https://api.influencer-flow.com
INFLUENCER_FLOW_API_URL=https://api.influencer-flow.com

# Authentication Token (get from Dashboard → Settings → API Keys)
INFLUENCER_FLOW_AUTH_TOKEN=your_auth_token_here
